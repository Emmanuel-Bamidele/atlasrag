{
  "name": "supavector-cli",
  "version": "0.1.0",
  "description": "SupaVector local CLI for onboarding, operations, and API workflows",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "supavector": "bin/supavector.js"
  },
  "files": [
    "bin/",
    "cli/",
    "gateway/",
    "sdk/",
    "atlasrag/",
    "deploy/",
    "docs/",
    "scripts/",
    ".env.example",
    ".env.external-postgres.example",
    ".env.prod.example",
    "docker-compose.yml",
    "docker-compose.external-postgres.yml",
    "docker-compose.prod.yml",
    "docker-compose.ec2.override.yml",
    "Dockerfile.node",
    "Dockerfile.redis",
    "Dockerfile.stunnel",
    "README.md",
    "QUICKSTART.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test:cli": "node cli/tests/cli_helpers.test.js && node cli/tests/admin_commands.test.js",
    "test:quickstart-smoke": "./scripts/test_quickstart_ci_local.sh",
    "test:oss-smoke": "./scripts/test_oss_ci_local.sh"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1"
  }
}
