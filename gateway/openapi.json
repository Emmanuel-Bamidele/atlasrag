{
  "openapi": "3.0.3",
  "info": {
    "title": "AtlasRAG API",
    "version": "1.0.0",
    "description": "AtlasRAG provides semantic search, RAG answers, and memory APIs for multi-tenant agent memory. All /v1 endpoints return a standard response envelope with { ok, data|error, meta }."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth" },
    { "name": "Docs" },
    { "name": "Search" },
    { "name": "Ask" },
    { "name": "Memory" },
    { "name": "Jobs" },
    { "name": "Metrics" }
  ],
  "security": [
    { "bearerAuth": [] },
    { "apiKeyAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "tenantId": { "type": ["string", "null"] },
          "collection": { "type": ["string", "null"] },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "enum": [true] },
          "data": { "type": "object" },
          "meta": { "$ref": "#/components/schemas/Meta" }
        },
        "required": ["ok", "data", "meta"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "enum": [false] },
          "error": {
            "type": "object",
            "properties": {
              "message": { "type": "string" },
              "code": { "type": ["string", "null"] }
            },
            "required": ["message"]
          },
          "meta": { "$ref": "#/components/schemas/Meta" }
        },
        "required": ["ok", "error", "meta"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "tenant": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["username", "password"]
      },
      "LoginResponseData": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" },
          "note": { "type": "string" }
        }
      },
      "ServiceToken": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "tenantId": { "type": "string" },
          "name": { "type": "string" },
          "principalId": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "lastUsedAt": { "type": ["string", "null"], "format": "date-time" },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" },
          "revokedAt": { "type": ["string", "null"], "format": "date-time" },
          "createdAt": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "ServiceTokenCreateRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "principalId": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "expiresAt": { "type": "string", "format": "date-time" },
          "tenantId": { "type": "string" }
        },
        "required": ["name"]
      },
      "ServiceTokenCreateResponseData": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "tokenInfo": { "$ref": "#/components/schemas/ServiceToken" },
          "note": { "type": "string" }
        }
      },
      "ServiceTokenListResponseData": {
        "type": "object",
        "properties": {
          "tokens": { "type": "array", "items": { "$ref": "#/components/schemas/ServiceToken" } }
        }
      },
      "ServiceTokenRevokeResponseData": {
        "type": "object",
        "properties": {
          "token": { "$ref": "#/components/schemas/ServiceToken" }
        }
      },
      "TenantAuthMode": {
        "type": "string",
        "enum": ["sso_only", "sso_plus_password", "password_only"]
      },
      "TenantSsoProvider": {
        "type": "string",
        "enum": ["google", "azure", "okta"]
      },
      "TenantSettings": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": ["string", "null"] },
          "authMode": { "$ref": "#/components/schemas/TenantAuthMode" },
          "ssoProviders": { "type": "array", "items": { "$ref": "#/components/schemas/TenantSsoProvider" } }
        }
      },
      "TenantSettingsResponseData": {
        "type": "object",
        "properties": {
          "tenant": { "$ref": "#/components/schemas/TenantSettings" }
        }
      },
      "TenantSettingsUpdateRequest": {
        "type": "object",
        "properties": {
          "authMode": { "$ref": "#/components/schemas/TenantAuthMode" },
          "ssoProviders": { "type": "array", "items": { "$ref": "#/components/schemas/TenantSsoProvider" } }
        }
      },
      "HealthResponseData": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "tcp": { "type": "string" }
        }
      },
      "DocListItem": {
        "type": "object",
        "properties": {
          "docId": { "type": "string" },
          "collection": { "type": "string" },
          "chunks": { "type": "integer" }
        }
      },
      "DocsListResponseData": {
        "type": "object",
        "properties": {
          "docs": { "type": "array", "items": { "$ref": "#/components/schemas/DocListItem" } },
          "totalDocs": { "type": "integer" }
        }
      },
      "DocIndexRequest": {
        "type": "object",
        "properties": {
          "docId": { "type": "string" },
          "text": { "type": "string" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" },
          "agentId": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "ttlSeconds": { "type": "number" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "principalId": { "type": "string" }
        },
        "required": ["docId", "text"]
      },
      "DocIndexUrlRequest": {
        "type": "object",
        "properties": {
          "docId": { "type": "string" },
          "url": { "type": "string" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" },
          "agentId": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "ttlSeconds": { "type": "number" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "principalId": { "type": "string" }
        },
        "required": ["docId", "url"]
      },
      "SearchResponseData": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chunkId": { "type": "string" },
                "score": { "type": "number" },
                "docId": { "type": "string" },
                "collection": { "type": "string" },
                "preview": { "type": "string" }
              }
            }
          }
        }
      },
      "AskRequest": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "k": { "type": "integer" },
          "docIds": { "type": "array", "items": { "type": "string" } },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        },
        "required": ["question"]
      },
      "AskResponseData": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "citations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chunkId": { "type": "string" },
                "docId": { "type": ["string", "null"] },
                "collection": { "type": ["string", "null"] }
              }
            }
          },
          "chunksUsed": { "type": "integer" },
          "k": { "type": "integer" }
        }
      },
      "MemoryType": {
        "type": "string",
        "enum": ["artifact", "semantic", "procedural", "episodic", "conversation", "summary"]
      },
      "MemoryReflectType": {
        "type": "string",
        "enum": ["semantic", "procedural", "summary"]
      },
      "MemoryItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "namespaceId": { "type": "string" },
          "type": { "$ref": "#/components/schemas/MemoryType" },
          "externalId": { "type": ["string", "null"] },
          "principalId": { "type": ["string", "null"] },
          "agentId": { "type": ["string", "null"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "title": { "type": ["string", "null"] },
          "sourceType": { "type": ["string", "null"] },
          "sourceUrl": { "type": ["string", "null"] },
          "metadata": { "type": ["object", "null"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" },
          "valueScore": { "type": ["number", "null"] },
          "reuseCount": { "type": "integer" },
          "lastUsedAt": { "type": ["string", "null"], "format": "date-time" },
          "utilityEma": { "type": "number" },
          "redundancyScore": { "type": "number" },
          "trustScore": { "type": "number" },
          "importanceHint": { "type": ["number", "null"] },
          "pinned": { "type": "boolean" }
        }
      },
      "MemoryWriteRequest": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "type": { "$ref": "#/components/schemas/MemoryType" },
          "title": { "type": "string" },
          "externalId": { "type": "string" },
          "metadata": { "type": "object" },
          "importanceHint": { "type": "number" },
          "pinned": { "type": "boolean" },
          "sourceType": { "type": "string" },
          "sourceUrl": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "ttlSeconds": { "type": "number" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "agentId": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "principalId": { "type": "string" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        },
        "required": ["text"]
      },
      "MemoryWriteResponseData": {
        "type": "object",
        "properties": {
          "memory": { "$ref": "#/components/schemas/MemoryItem" },
          "chunksIndexed": { "type": "integer" },
          "truncated": { "type": "boolean" }
        }
      },
      "MemoryRecallRequest": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "k": { "type": "integer" },
          "types": { "type": "array", "items": { "$ref": "#/components/schemas/MemoryType" } },
          "since": { "type": "string", "format": "date-time" },
          "until": { "type": "string", "format": "date-time" },
          "agentId": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        },
        "required": ["query"]
      },
      "MemoryRecallResponseData": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "k": { "type": "integer" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chunkId": { "type": "string" },
                "score": { "type": "number" },
                "preview": { "type": "string" },
                "memory": { "$ref": "#/components/schemas/MemoryItem" }
              }
            }
          }
        }
      },
      "MemoryReflectRequest": {
        "type": "object",
        "properties": {
          "docId": { "type": "string" },
          "artifactId": { "type": "string" },
          "conversationId": { "type": "string" },
          "types": { "type": "array", "items": { "$ref": "#/components/schemas/MemoryReflectType" } },
          "maxItems": { "type": "integer" },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "principalId": { "type": "string" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        }
      },
      "MemoryCleanupRequest": {
        "type": "object",
        "properties": {
          "before": { "type": "string", "format": "date-time" },
          "limit": { "type": "integer" },
          "dryRun": { "type": "boolean" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        }
      },
      "MemoryCompactRequest": {
        "type": "object",
        "properties": {
          "types": { "type": "array", "items": { "$ref": "#/components/schemas/MemoryType" } },
          "since": { "type": "string", "format": "date-time" },
          "until": { "type": "string", "format": "date-time" },
          "maxItems": { "type": "integer" },
          "summaryType": { "$ref": "#/components/schemas/MemoryType" },
          "deleteOriginals": { "type": "boolean" },
          "visibility": { "type": "string", "enum": ["tenant", "private", "acl"] },
          "acl": { "type": "array", "items": { "type": "string" } },
          "principalId": { "type": "string" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "properties": {
          "memoryId": { "type": "string" },
          "feedback": { "type": "string", "enum": ["positive", "negative"] },
          "eventValue": { "type": "number" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        },
        "required": ["memoryId", "feedback"]
      },
      "FeedbackResponseData": {
        "type": "object",
        "properties": {
          "memoryId": { "type": "string" },
          "eventType": { "type": "string" },
          "valueScore": { "type": ["number", "null"] }
        }
      },
      "TaskEventRequest": {
        "type": "object",
        "properties": {
          "memoryId": { "type": "string" },
          "eventType": { "type": "string", "enum": ["task_success", "task_fail"] },
          "eventValue": { "type": "number" },
          "collection": { "type": "string" },
          "tenantId": { "type": "string" }
        },
        "required": ["memoryId", "eventType"]
      },
      "TaskEventResponseData": {
        "type": "object",
        "properties": {
          "memoryId": { "type": "string" },
          "eventType": { "type": "string" },
          "eventValue": { "type": "number" },
          "utilityEma": { "type": "number" },
          "trustScore": { "type": "number" },
          "valueScore": { "type": ["number", "null"] }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "jobType": { "type": "string" },
          "error": { "type": ["string", "null"] },
          "input": { "type": ["object", "null"] },
          "output": { "type": ["object", "null"] },
          "attempts": { "type": "integer" },
          "maxAttempts": { "type": ["integer", "null"] },
          "nextRunAt": { "type": ["string", "null"], "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "JobResponseData": {
        "type": "object",
        "properties": {
          "job": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "status": { "type": "string" }
            }
          }
        }
      },
      "JobStatusResponseData": {
        "type": "object",
        "properties": {
          "job": { "$ref": "#/components/schemas/Job" }
        }
      },
      "StatsResponseData": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "paths": {
    "/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/HealthResponseData" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with username/password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/LoginResponseData" } } }
                  ]
                }
              }
            }
          },
          "400": { "description": "Invalid request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v1/admin/tenant": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get tenant settings (admin)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/TenantSettingsResponseData" } } }
                  ]
                }
              }
            }
          },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "tags": ["Auth"],
        "summary": "Update tenant settings (admin)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TenantSettingsUpdateRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/TenantSettingsResponseData" } } }
                  ]
                }
              }
            }
          },
          "400": { "description": "Invalid request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v1/admin/service-tokens": {
      "get": {
        "tags": ["Auth"],
        "summary": "List service tokens (admin)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ServiceTokenListResponseData" } } }
                  ]
                }
              }
            }
          },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "tags": ["Auth"],
        "summary": "Create service token (admin)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ServiceTokenCreateRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ServiceTokenCreateResponseData" } } }
                  ]
                }
              }
            }
          },
          "400": { "description": "Invalid request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v1/admin/service-tokens/{id}": {
      "delete": {
        "tags": ["Auth"],
        "summary": "Revoke service token (admin)",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ServiceTokenRevokeResponseData" } } }
                  ]
                }
              }
            }
          },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v1/docs": {
      "get": {
        "tags": ["Docs"],
        "summary": "List indexed docs",
        "parameters": [
          { "in": "query", "name": "collection", "schema": { "type": "string" } },
          { "in": "query", "name": "tenantId", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkResponse" },
                    { "properties": { "data": { "$ref": "#/components/schemas/DocsListResponseData" } } }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Docs"],
