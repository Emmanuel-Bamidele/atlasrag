    "MEMORY_TIER_EVICT": "0.20",
    "MEMORY_INIT_VALUE": "0.50",
    "MEMORY_ACCESS_ALPHA": "0.08",
    "MEMORY_CONTRIBUTION_BETA": "0.20",
    "MEMORY_NEGATIVE_STEP": "0.08"
