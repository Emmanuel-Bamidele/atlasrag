  "workload": {
    "writes": 50000,
    "min_asks": 10000,
    "recall_k": 24,
    "ask_k": 48,
    "ttl_seconds": 2592000,
    "snapshot_every": 1000,
    "concurrency": 24,
    "log_every": 1000,
    "request_timeout_ms": 120000,
    "max_retries": 5
  }
